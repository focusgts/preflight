# Black Hole for Adobe Marketing Cloud — Environment Configuration
# Copy this file to .env and fill in the values.

# ---------- AI Service ----------
# Optional: Anthropic API key for AI-powered assessments.
# When omitted, the system falls back to heuristic-based scoring.
ANTHROPIC_API_KEY=

# ---------- Data Storage ----------
# Path to SQLite database file (relative to project root or absolute).
DATABASE_PATH=./data/blackhole.db

# Directory for uploaded files (migration exports, connector configs, etc.).
UPLOAD_DIR=./data/uploads

# ---------- Security ----------
# Secret used for signing session cookies. Generate a strong random value.
# Example: openssl rand -base64 32
SESSION_SECRET=change-me-in-production

# ---------- Runtime ----------
# Environment: development | production | test
NODE_ENV=development

# Port the server listens on.
PORT=3000
