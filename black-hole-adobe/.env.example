# Black Hole for Adobe Marketing Cloud
# Copy this file to .env.local and fill in your values

# -----------------------------------------------------------------------
# Admin credentials (created on first login if no admin exists)
# -----------------------------------------------------------------------
BH_ADMIN_EMAIL=admin@blackhole.io
BH_ADMIN_PASSWORD=admin123

# -----------------------------------------------------------------------
# Database (SQLite — defaults to .data/blackhole.sqlite)
# -----------------------------------------------------------------------
# DATABASE_PATH=./.data/blackhole.sqlite

# -----------------------------------------------------------------------
# Navigator Bridge (optional — connects to Focus GTS Navigator Portal)
# -----------------------------------------------------------------------
NAVIGATOR_API_URL=
NAVIGATOR_API_KEY=

# -----------------------------------------------------------------------
# Lead capture webhook (optional — Slack, Zapier, Teams, etc.)
# POST with Slack-compatible JSON on every new lead signup
# -----------------------------------------------------------------------
BH_LEAD_WEBHOOK_URL=

# -----------------------------------------------------------------------
# AEM Connection (for live connector testing)
# -----------------------------------------------------------------------
AEM_AUTHOR_URL=
AEM_ACCESS_TOKEN=

# -----------------------------------------------------------------------
# AI / Claude (optional — enables AI-powered assessment features)
# -----------------------------------------------------------------------
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------
# Next.js
# -----------------------------------------------------------------------
# NEXT_PUBLIC_BASE_URL=http://localhost:3000
# NODE_ENV=development
